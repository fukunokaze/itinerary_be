# Copy this file to .env and fill in real values. .env is gitignored.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=itinerary
POSTGRES_PORT=5432

# WebAPI
WEBAPI_PORT=8080

# JWT (any long random string locally; use a real secret in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ISSUER=itinerary-be
JWT_AUDIENCE=itinerary-be-client

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000
